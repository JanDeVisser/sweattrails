{
    "name": "sweattrails",
    "key": "SWEATTRAILS",
    "includes" : [
	"map.h"
    ],
    "tables": [
	{
	    "key": "ACTIVITY",
	    "table_name": "activity",
	    "name": "activity",
	    "columns": [
		{ "type": "serial",   "name": "id", "pk": true },
		{ "ref": "file",      "name": "files", "cardinality": "1-n", "fk_column": "activity_id"},
		{ "type": "slice_t",  "name": "description" },
		{ "type": "uint32_t", "name": "start_time" },
		{ "type": "uint32_t", "name": "end_time" },
	    ]
	},
	{
	    "key": "FILE",
	    "table_name": "file",
	    "name": "file",
	    "columns": [
		{ "type": "serial",   "name": "id", "pk": true },
		{ "ref": "activity",  "name": "activity_id", "cardinality": "n-1" },
		{ "ref": "session",   "name": "sessions", "cardinality": "1-n", "fk_column": "file_id"},
		{ "type": "slice_t",  "name": "file_name" },
		{ "type": "uint32_t", "name": "start_time" },
		{ "type": "uint32_t", "name": "end_time" },
		{ "type": "uint32_t", "name": "serial_number" }
	    ]
	},
	{
	    "key": "SESSION",
	    "table_name": "session",
	    "name": "session",
	    "columns": [
		{ "type": "serial",   "name": "id", "pk": true },
		{ "ref": "file",      "name": "file_id", "cardinality": "n-1" },
		{ "ref": "record",    "name": "records", "cardinality": "1-n", "fk_column": "session_id"},
		{ "ref": "lap",       "name": "laps", "cardinality": "1-n", "fk_column": "session_id"},
		{ "type": "uint32_t", "name": "sport" },
		{ "type": "uint32_t", "name": "sub_sport" },
		{ "type": "uint32_t", "name": "timestamp" },
		{ "type": "slice_t",  "name": "description" },
		{ "type": "uint32_t", "name": "start_time" },
		{ "type": "uint32_t", "name": "end_time" },
		{ "type": "float",    "name": "elapsed_time" },
		{ "type": "float",    "name": "moving_time" },
		{ "type": "float",    "name": "distance" },
		{ "type": "float",    "name": "min_elevation" },
		{ "type": "float",    "name": "max_elevation" },
		{ "type": "float",    "name": "avg_elevation" },
		{ "type": "float",    "name": "max_power" },
		{ "type": "float",    "name": "avg_power" },
		{ "type": "float",    "name": "max_speed" },
		{ "type": "float",    "name": "avg_speed" },
		{ "type": "uint32_t", "name": "min_hr" },
		{ "type": "uint32_t", "name": "max_hr" },
		{ "type": "uint32_t", "name": "avg_hr" },
		{ "type": "Vector2",  "name": "time_range" },
		{ "type": "box_t",    "name": "route_area", "optional": true },
		{ "type": "atlas_t",  "name": "atlas", "transient": true },
	    ]
	},
	{
	    "key": "LAP",
	    "table_name": "lap",
	    "name": "lap",
	    "columns": [
		{ "type": "serial",   "name": "id", "pk": true },
		{ "ref": "session",   "name": "session_id", "cardinality": "n-1" },
		{ "ref": "record",    "name": "records", "cardinality": "1-n", "fk_column": "lap_id"},
		{ "type": "uint32_t", "name": "timestamp" },
		{ "type": "slice_t",  "name": "description" },
		{ "type": "uint32_t", "name": "start_time" },
		{ "type": "uint32_t", "name": "end_time" },
		{ "type": "float",    "name": "elapsed_time" },
		{ "type": "float",    "name": "moving_time" },
		{ "type": "float",    "name": "distance" },
		{ "type": "float",    "name": "min_elevation" },
		{ "type": "float",    "name": "max_elevation" },
		{ "type": "float",    "name": "avg_elevation" },
		{ "type": "float",    "name": "max_power" },
		{ "type": "float",    "name": "avg_power" },
		{ "type": "float",    "name": "max_speed" },
		{ "type": "float",    "name": "avg_speed" },
		{ "type": "uint32_t", "name": "min_hr" },
		{ "type": "uint32_t", "name": "max_hr" },
		{ "type": "uint32_t", "name": "avg_hr" },
		{ "type": "Vector2",  "name": "time_range" },
		{ "type": "box_t",    "name": "route_area", "optional": true},
		{ "type": "atlas_t",  "name": "atlas", "transient": true},
	    ]
	},
	{
	    "key": "RECORD",
	    "table_name": "record",
	    "name": "record",
	    "columns": [
		{ "type": "serial",        "name": "id", "pk": true },
		{ "ref": "session",        "name": "session_id", "cardinality": "n-1" },
		{ "type": "uint32_t",      "name": "timestamp" },
		{ "type": "coordinates_t", "name": "position", "optional": true},
		{ "type": "float",         "name": "elevation" },
		{ "type": "float",         "name": "distance" },
		{ "type": "float",         "name": "power" },
		{ "type": "float",         "name": "speed" },
		{ "type": "float",         "name": "hr" }
	    ]
	}
    ]
}
